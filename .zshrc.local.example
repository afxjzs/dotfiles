# Machine-specific and private configuration.
# Copy this to ~/.zshrc.local and fill in your values.
# This file is sourced by .zshrc but is NOT committed to the repo.

# --- Secrets ---
export AWS_ACCESS_KEY="your-access-key"
export AWS_SECRET_KEY="your-secret-key"
export NEXUS_API_TOKEN="your-token"

export S3_BUCKET_DEV="your-dev-bucket"
export S3_BUCKET_STAG="your-staging-bucket"
export S3_BUCKET_PROD="your-prod-bucket"
export ENVIRONMENT="DEV"
export DROPBOX_ACCESS_TOKEN='your-dropbox-token'

# --- App-specific aliases ---
# alias snowsql=/Applications/SnowSQL.app/Contents/MacOS/snowsql

# --- Machine-specific paths ---
# export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
# export PATH="$PATH:/Applications/Postgres.app/Contents/Versions/latest/bin"

# export JAVA_HOME=/Library/Java/JavaVirtualMachines/your-jdk.jdk/Contents/Home

# Android SDK
# export ANDROID_HOME=/opt/homebrew/share/android-commandlinetools
# export PATH=$PATH:$ANDROID_HOME/platform-tools:$ANDROID_HOME/cmdline-tools/latest/bin

# Flutter
# export PATH="$PATH":"$HOME/.pub-cache/bin"

